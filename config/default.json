{
  "app": {
    "name": "relay",
    "port": 3000,
    "domain": "demo.com"
  },
  "server": {
    "cache": true,
    "secure": true,
    "cors": "*",
    "rateLimit": {
      "windowMs": 60000,
      "max": 100,
      "standardHeaders": true,
      "legacyHeaders": false
    },
    "https": {
      "pubKey": "/etc/relay/certs/fullchain.pem",
      "pvtKey": "/etc/relay/certs/privkey.pem"
    }
  },
  "storage": {
    "projectsDirectory": "/var/lib/relay/projects",
    "uploadsDirectory": "/var/lib/relay/uploads"
  },
  "hasura": {
    "endpoint": "http://localhost:8080/v1/graphql",
    "adminSecret": "w8zwV4wtyHq9EakOHAUbWtlX0TVBMaUWUnN8lZjlrw8="
  },
  "cache": {
    "ttl": 360
  }
}
