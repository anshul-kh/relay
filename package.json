{
  "name": "relay",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "tsc && bun --watch index.ts",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check": "bun run format:check && bun run typecheck",
    "prepare": "husky",
    "start": "bun index.ts",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/config": "^4.4.0",
    "@types/express": "^5.0.6",
    "@types/mime-types": "^3.0.1",
    "husky": "^9.1.7",
    "prettier": "^3.8.3"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "config": "^4.4.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.1",
    "mime-types": "^3.0.2",
    "node-cache": "^5.1.2"
  }
}
